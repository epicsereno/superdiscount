{
  "$schema": "tokens/typography",
  "font": {
    "display": {
      "family": "'Barlow Condensed', 'Arial Narrow', sans-serif",
      "weights": [700, 800],
      "transform": "uppercase",
      "tracking": "0.02em",
      "google": "Barlow+Condensed:wght@700;800"
    },
    "body": {
      "family": "'DM Sans', system-ui, sans-serif",
      "weights": [400, 500, 700],
      "google": "DM+Sans:wght@400;500;700"
    }
  },
  "scale": {
    "xs": "0.75rem",
    "sm": "0.875rem",
    "base": "1rem",
    "lg": "1.125rem",
    "xl": "1.375rem",
    "2xl": "1.75rem",
    "3xl": "2.25rem",
    "hero": "clamp(2.5rem, 9vw, 4.5rem)"
  },
  "leading": { "tight": 1.1, "normal": 1.5 }
}
